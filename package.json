{
  "name": "simple-slack-notify",
  "version": "1.0.4",
  "description": "Slack notification action that just works",
  "author": "Adam K Dean <adamkdean@googlemail.com>",
  "license": "MIT",
  "keywords": [
    "slack",
    "notify",
    "notification",
    "github action",
    "action"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamkdean/simple-slack-notify.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "all": "yarn run lint && yarn run format-check && yarn run build",
    "build": "ncc build src/index.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "format-check": "prettier --check src/**/*.js"
  },
  "dependencies": {
    "@actions/core": "^1.2.6",
    "@actions/github": "^5.1.1",
    "@slack/webhook": "^6.1.0"
  },
  "devDependencies": {
    "@zeit/ncc": "^0.22.3",
    "eslint": "^8.35.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-n": "^15.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "prettier": "^2.0.5"
  }
}
